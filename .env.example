# ===== 签到清单 配置 =====

# 访问密码（单人登录用）。部署脚本会自动生成一个强随机密码，
# 你也可以直接改成自己好记的强密码，改完重启服务即可生效。
APP_PASSWORD=change-this-password

# 服务监听端口
PORT=3000

# 数据库文件路径（默认 ./data/checkin.db）
# DB_PATH=./data/checkin.db

# 设为 true 可完全关闭登录（仅限可信内网环境，公网请勿开启）
# AUTH_DISABLED=false

# ===== 反向代理 / HTTPS（如 Cloudflare、Nginx、Caddy）=====
# 在反向代理后面时设为代理层数（通常为 1），使登录限速能识别真实客户端 IP
# TRUST_PROXY=1
# 走 HTTPS 时设为 true（Cookie 仅在加密连接下发送，更安全）。
# ⚠️ 纯 HTTP 访问时务必保持 false/留空，否则登录后 Cookie 不会被发送
# SECURE_COOKIE=true

